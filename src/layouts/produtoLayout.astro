---
import Layout from "./layout.astro";
import "../styles/produtoLayout.css";
const { produto } = Astro.props;
---

<Layout title={produto.name}>
  <section class="produto-detalhe">
    <img src={produto.image} alt={produto.name} />

    <div class="produto-info">
      <h2>{produto.name} Vol. {produto.volume}</h2>
      <p class="produto-preco">Preço: R$ {produto.price}</p>

      <div class="produto-card-interno">
        <p>Em estoque</p>
        <label for="quantidade">Quantidade:</label>
        <select id="quantidade">
          {Array.from({ length: produto.stock }, (_, i) => i + 1).map((qtd) => (
            <option value={qtd}>{qtd}</option>
          ))}
        </select>
      </div>

      <div class="btn-wrapper">
        <button 
          id="btn-carrinho" 
          data-id={produto.id} 
          data-stock={produto.stock}
          data-nome={produto.name}
          data-preco={produto.price}
          data-imagem={produto.image}
          data-volume={produto.volume}
          disabled={produto.stock === 0}>
          {produto.stock === 0 ? "Produto esgotado" : "Adicionar ao Carrinho"}
        </button>
      </div>
    </div>
  </section>

  <section class="produto-descricao">
    <h3>Detalhes do Produto</h3>
    <p><strong>Nome:</strong> {produto.name}</p>
    <p><strong>Volume:</strong> {produto.volume}</p>
    <p><strong>Autor:</strong> {produto.author}</p>
    <p><strong>Descrição:</strong> {produto.description}</p>
    <p><strong>Categoria:</strong> {produto.category}</p>
    <p><strong>Idioma:</strong> Português(Brasil)</p>
  </section>

  <section class="comentarios">
    <h3>Comentários</h3>
    {produto.comments && produto.comments.length > 0 ? (
      produto.comments.map((texto) => (
        <div class="comentario">
          <p>{texto}</p>
        </div>
      ))
    ) : (
      <p>Este produto ainda não possui comentários.</p>
    )}
  </section>

  <script>
    const botao = document.getElementById("btn-carrinho");
    if (botao && !botao.disabled) {
      botao.addEventListener("click", () => {
        const idProduto = botao.dataset.id;
        const estoque = parseInt(botao.dataset.stock);
        const qtd = parseInt(document.getElementById("quantidade").value);

        if (qtd > estoque) {
          alert("Quantidade maior que o estoque disponível!");
          return;
        }

        let carrinho = JSON.parse(localStorage.getItem("carrinho")) || [];
        const itemExistente = carrinho.find((item) => item.id == idProduto);

        if (itemExistente) {
          const novaQtd = itemExistente.quantidade + qtd;
          if (novaQtd > estoque) {
            alert("Não é possível adicionar mais do que o estoque disponível!");
            return;
          }
          itemExistente.quantidade = novaQtd;
        } else {
          carrinho.push({
            id: idProduto,
            nome: botao.dataset.nome,
            preco: parseFloat(botao.dataset.preco),
            imagem: botao.dataset.imagem,
            volume: botao.dataset.volume,
            quantidade: qtd
          });
        }

        localStorage.setItem("carrinho", JSON.stringify(carrinho));
        alert("Produto adicionado ao carrinho!");
      });
    }
  </script>
</Layout>